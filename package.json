{
  "name": "coupang-supplier-automation",
  "version": "1.0.18",
  "description": "쿠팡 서플라이어 허브 Electron 자동화 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "predev": "node scripts/prepare-flavor.js tbnws",
    "dev": "concurrently -k -n webpack,electron -c blue,magenta \"npx webpack serve --mode development\" \"wait-on tcp:3100 && electron .\"",
    "build:renderer": "npx webpack --mode production",
    "prebuild:notes": "node scripts/prepare-release-notes.js",
    "build": "node scripts/build.js tbnws",
    "build:basic": "node scripts/build.js basic",
    "build:tbnws": "node scripts/build.js tbnws",
    "test:ui": "node run-ui-test.js",
    "test:lib": "node test-excel-lib.js",
    "test:python": "node test-python-bridge.js",
    "test:browser": "cd python && python test_browser.py",
    "test:login": "cd python && python test_login.py",
    "test:login-script": "cd python && python test_login_script.py",
    "test:po-download": "cd python && python test_po_download.py",
    "test:po-download:offline": "cd python && python test_po_download_offline.py",
    "test:integration": "node -e \"const{execFileSync}=require('child_process');const e=require('electron');const p=require('path');const env={...process.env};delete env.ELECTRON_RUN_AS_NODE;env.ELECTRON_LOAD_DIST='1';try{console.log(execFileSync(e,[p.join(__dirname,'test-integration.js')],{env,timeout:90000,encoding:'utf-8',stdio:['pipe','pipe','pipe']}))}catch(x){if(x.stdout)console.log(x.stdout);process.exit(x.status||1)}\"",
    "test:cdp": "node test-cdp-attach.js",
    "preflight": "node preflight.js",
    "preflight:json": "node preflight.js --json",
    "python:venv:create": "python -m venv python/.venv",
    "python:venv:install": "python/.venv/Scripts/pip.exe install -r python/requirements.txt || python/.venv/bin/pip install -r python/requirements.txt",
    "test": "node preflight.js && npm run test:lib && npm run test:python && npm run test:browser && npm run build:renderer && npm run test:ui",
    "lint": "echo \"ESLint not yet configured\""
  },
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@electron/fuses": "^1.8.0",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  },
  "build": {
    "appId": "com.tbnws.coupang-supplier-automation",
    "productName": "쿠팡 서플라이어 자동화",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "ipc-handlers.js",
      "license-service.js",
      "update-service.js",
      "plugin-main-loader.js",
      "src/core/poStyler.js",
      "src/core/confirmationBuilder.js",
      "src/core/deliveryCompanies.js",
      "package.json",
      "!**/*.{md,test.js,spec.js}",
      "!docs/**",
      "!scripts/**",
      "!python/.venv/**",
      "!python/__pycache__/**"
    ],
    "asar": true,
    "asarUnpack": [
      "python/**/*",
      "**/*.node"
    ],
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "afterPack": "./scripts/electron-fuses.js",
    "releaseInfo": {
      "releaseNotesFile": "release-notes/latest.md"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "BOSEON-SEO",
        "repo": "coupang-supplier-releases",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "verifyUpdateCodeSignature": false,
      "artifactName": "coupang-supplier-automation-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "쿠팡 서플라이어 자동화"
    }
  },
  "dependencies": {
    "@fortune-sheet/react": "^1.0.4",
    "coupang-supplier-plugin-tbnws": "github:BOSEON-SEO/coupang-supplier-plugin-tbnws#main",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "luckyexcel": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  }
}
