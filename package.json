{
  "name": "coupang-supplier-automation",
  "version": "0.1.0",
  "description": "쿠팡 서플라이어 허브 Electron 자동화 앱",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npx webpack serve --mode development\" \"wait-on http://localhost:3000 && electron .\"",
    "build:renderer": "npx webpack --mode production",
    "build": "npm run build:renderer && electron-builder",
    "lint": "echo \"ESLint not yet configured\""
  },
